5) Função troca para float
void troca(float *a, float *b) { float temp; temp = *a; *a = *b; *b = temp; }
 
 
#include <stdio.h>
 
void troca (int *i, int *j) {
    int temp;
    temp = *i;
    *i = *j;
    *j = temp;
}
 
int main() {
    int a = 4, b = 9;
 
    troca(&a, &b);
 
    printf("a = %d\n", a);
    printf("b = %d\n", b);
 
    return 0;
}
